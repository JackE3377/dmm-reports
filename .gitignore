# ============================================================
#  dmm-reports — PUBLIC REPO 보안 .gitignore
#  허용 목록(allowlist) 방식: 명시적으로 허용한 파일만 추적
#  .env, 코드, DB, 로그 등 민감 파일은 절대 업로드 불가
# ============================================================

# ── 1단계: 루트의 모든 파일/폴더 차단 ──────────────────────
/*

# ── 2단계: 허용할 파일만 예외 처리 ─────────────────────────
!.gitignore
!app.py
!requirements.txt
!reports/

# ── 3단계: reports/ 내부도 기본 차단 후 HTML만 허용 ─────────
/reports/*
!/reports/.gitkeep
!/reports/*_Sourcing_Daily.html

# ── 절대 허용 금지 (명시적 이중 차단) ───────────────────────
.env
.env.*
*.env
*.key
*.pem
*.db
*.sqlite
*.sqlite3
*.log
*.bat
*.xml
*.json
*.py
__pycache__/
*.pyc
data/
output/
